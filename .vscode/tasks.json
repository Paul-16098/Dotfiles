{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "process",
			"label": "watch: yazi config update",
			"command": "nu",
			"args": [
				"-c",
				"watch ./AppData/Roaming/yazi/config/yazi.raw.toml { nu .vscode/yazi-config-update.nu }"
			],
			"problemMatcher": [],
			"isBackground": true,
			"runOptions": {
				"instanceLimit": 1,
				"instancePolicy": "terminateOldest"
			}
		},
		{
			"type": "process",
			"label": "yazi config update",
			"command": "nu",
			"args": [".vscode/yazi-config-update.nu"],
			"problemMatcher": []
		},
		{
			"type": "process",
			"label": "update numd doc",
			"command": "nu",
			"args": [".vscode/update-numd-doc.nu"],
			"problemMatcher": [],
			"options": {
				"env": {
					"NU_LIB_DIRS": "~\\.config\\nushell\\nupm\\modules"
				}
			}
		},
		{
			"type": "process",
			"label": "chezmoi: apply",
			"command": "chezmoi",
			"args": ["apply"],
			"problemMatcher": []
		}
	]
}

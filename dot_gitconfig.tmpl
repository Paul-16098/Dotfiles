[core]
	editor = code-insiders --wait
	preloadindex = true
	autocrlf = true
	compression = 3
	longpaths = true
	quotepath = false
	fileMode = false
	commitGraph = true
	fsmonitor = true
	untrackedCache = true

[gc]
	writeCommitGraph = true

[fetch]
	writeCommitGraph = true

[user]
	name = {{ .GH_NAME }}
	email = {{ .EMAIL }}
	signingkey = {{ .SIGN_KEY_ID }}
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[push]
	autoSetupRemote = true
[commit]
	gpgsign = true
[tag]
	gpgSign = true
[gpg]
	{{- if eq .SIGN_BY "gpg" }}
	format = openpgp
	program = "{{ osClean (lookPath "gpg") | replace "\\" "\\\\" }}"
	{{- else if eq .SIGN_BY "ssh" }}
	format = ssh
	{{- else }}
	{{ warnf "Invalid signing method: %s. No signing will be used." .SIGN_BY}}
	{{- end }}
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[http]
	postBuffer = 524288000

[sendemail]
	smtpEncryption = tls
	smtpServer = smtp.gmail.com
	smtpUser = {{ .EMAIL }}
	smtpServerPort = 587
[checkout]
	workers = 0

[credential]
	helper = manager
[credential "https://github.com"]
	helper = 
	helper = !'C:\\Program Files (x86)\\GitHub CLI\\gh.exe' auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !'C:\\Program Files (x86)\\GitHub CLI\\gh.exe' auth git-credential
[url "https://{{ .GH_NAME }}@gitlab.com/"]
	insteadOf = https://gitlab.com/


[merge]
	tool = vscode
[diff]
	guitool = vscode
	algorithm = patience

[difftool]
	prompt = false
[difftool "vscode"]
	path = "code-insiders"
[difftool "zed"]
	cmd = "zed --diff $LOCAL $REMOTE"
